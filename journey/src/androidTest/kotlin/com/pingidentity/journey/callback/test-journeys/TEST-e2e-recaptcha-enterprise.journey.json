      "scripts": {
        "4703400d-5b27-4c98-97f8-495b7ae5ca1d": {
          "_id": "4703400d-5b27-4c98-97f8-495b7ae5ca1d",
          "context": "AUTHENTICATION_TREE_DECISION_NODE",
          "createdBy": "id=38622431-993f-4f4f-b21a-0bf5a1bc647d,ou=user,ou=am-config",
          "creationDate": 1731544114915,
          "default": false,
          "description": "null",
          "evaluatorVersion": "1.0",
          "language": "JAVASCRIPT",
          "lastModifiedBy": "id=38622431-993f-4f4f-b21a-0bf5a1bc647d,ou=user,ou=am-config",
          "lastModifiedDate": 1731546490713,
          "name": "captcha_failure",
          "script": "\"/*\\n  - This script shared state for CaptchaEnterpriseNode.FAILURE \\n  - and returns it to the caller in a TextOutputCallback\\n */\\n\\nvar fr = JavaImporter(\\n     org.forgerock.openam.auth.node.api.Action, \\n     javax.security.auth.callback.TextOutputCallback\\n )\\n\\nlogger.error(\\\"captcha_failure: start script...\\\");\\n\\n if (callbacks.isEmpty()) {\\n   if (transientState.get(\\\"CaptchaEnterpriseNode.FAILURE\\\")) {\\n     var captchaFailure = transientState.get(\\\"CaptchaEnterpriseNode.FAILURE\\\")\\n     logger.error(captchaFailure)\\n     action = fr.Action.send(\\n       new fr.TextOutputCallback(\\n         fr.TextOutputCallback.ERROR, \\n         captchaFailure\\n       )\\n     ).build()\\n   }\\n\\n  } else {\\n    action = fr.Action.goTo(\\\"true\\\").build()\\n  }\\n  \\n  outcome = \\\"true\\\";\\n\""
        },
        "a642ad67-43e4-4504-8d0e-b61938197bdc": {
          "_id": "a642ad67-43e4-4504-8d0e-b61938197bdc",
          "context": "AUTHENTICATION_TREE_DECISION_NODE",
          "createdBy": "id=38622431-993f-4f4f-b21a-0bf5a1bc647d,ou=user,ou=am-config",
          "creationDate": 1731544114918,
          "default": false,
          "description": "null",
          "evaluatorVersion": "1.0",
          "language": "JAVASCRIPT",
          "lastModifiedBy": "id=38622431-993f-4f4f-b21a-0bf5a1bc647d,ou=user,ou=am-config",
          "lastModifiedDate": 1731544114918,
          "name": "captcha_custom_payload",
          "script": "\"/*\\n  - Data made available by nodes that have already executed are available in the sharedState variable.\\n  - The script should set outcome to either \\\"true\\\" or \\\"false\\\".\\n */\\n\\nlogger.error(\\\"captcha_custom_payload: start script...\\\");\\nvar customPayload = JSON.parse(\\\"{\\\\\\\"userInfo\\\\\\\": {\\\\\\\"accountId\\\\\\\": \\\\\\\"user_account_id_123\\\\\\\"}}\\\");\\nsharedState.put(\\\"CaptchaEnterpriseNode.PAYLOAD\\\", customPayload);\\noutcome = \\\"true\\\";\""
        },
        "ad63e311-7e85-4ade-b8d7-71a4554ec11d": {
          "_id": "ad63e311-7e85-4ade-b8d7-71a4554ec11d",
          "context": "AUTHENTICATION_TREE_DECISION_NODE",
          "createdBy": "id=38622431-993f-4f4f-b21a-0bf5a1bc647d,ou=user,ou=am-config",
          "creationDate": 1731544114916,
          "default": false,
          "description": "null",
          "evaluatorVersion": "1.0",
          "language": "JAVASCRIPT",
          "lastModifiedBy": "id=38622431-993f-4f4f-b21a-0bf5a1bc647d,ou=user,ou=am-config",
          "lastModifiedDate": 1731544114916,
          "name": "captcha_assessment_result",
          "script": "\"/*\\n  - This script checks transientState for CaptchaEnterpriseNode.ASSESSMENT_RESULT \\n  - and returns them to the caller in a TextOutputCallback\\n */\\n\\nvar fr = JavaImporter(\\n     org.forgerock.openam.auth.node.api.Action, \\n     javax.security.auth.callback.TextOutputCallback\\n)\\n\\nlogger.error(\\\"captcha_assessment_result: start script...\\\");\\n\\nif (callbacks.isEmpty()) {\\n   if (transientState.get(\\\"CaptchaEnterpriseNode.ASSESSMENT_RESULT\\\")) {\\n     logger.message(\\\"captcha_assessment_result: \\\" + transientState.get(\\\"CaptchaEnterpriseNode.ASSESSMENT_RESULT\\\"))\\n     var captchaAssessment = transientState.get(\\\"CaptchaEnterpriseNode.ASSESSMENT_RESULT\\\")\\n     action = fr.Action.send(\\n        new fr.TextOutputCallback(\\n          fr.TextOutputCallback.INFORMATION, \\n          JSON.stringify(captchaAssessment)\\n        )\\n     ).build()\\n   }\\n} else {\\n  action = fr.Action.goTo(\\\"true\\\").build()\\n}\\n  \\noutcome = \\\"true\\\";\\n\""
        },
        "e73fcd84-dd57-4efc-8830-768738a4d1d3": {
          "_id": "e73fcd84-dd57-4efc-8830-768738a4d1d3",
          "context": "AUTHENTICATION_TREE_DECISION_NODE",
          "createdBy": "id=38622431-993f-4f4f-b21a-0bf5a1bc647d,ou=user,ou=am-config",
          "creationDate": 1731544114915,
          "default": false,
          "description": "null",
          "evaluatorVersion": "2.0",
          "language": "JAVASCRIPT",
          "lastModifiedBy": "id=38622431-993f-4f4f-b21a-0bf5a1bc647d,ou=user,ou=am-config",
          "lastModifiedDate": 1731544114915,
          "name": "request-platform-decision",
          "script": "\"if (requestHeaders.get(\\\"x-requested-platform\\\")) {\\n  if (requestHeaders.get(\\\"x-requested-platform\\\").get(0).indexOf(\\\"android\\\") !== -1) {\\n      action.goTo(\\\"android\\\");\\n  } else if(requestHeaders.get(\\\"x-requested-platform\\\").get(0).indexOf(\\\"ios\\\") !== -1) {\\n      action.goTo(\\\"ios\\\");\\n  } else if(requestHeaders.get(\\\"x-requested-platform\\\").get(0).indexOf(\\\"javascript\\\") !== -1) {\\n      action.goTo(\\\"js\\\");\\n  } else {\\n      action.goTo(\\\"unknown\\\");\\n  }\\n}\\nelse {\\n  action.goTo(\\\"unknown\\\");\\n}\\n\""
        }
      },
