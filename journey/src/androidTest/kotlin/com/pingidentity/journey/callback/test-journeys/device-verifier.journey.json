          "name": "Device Signing JWT",
          "script": "\"var signJWT = nodeState.get(\\\"DeviceSigningVerifierNode.JWT\\\")\\n\\nif (signJWT) {\\n  logger.error(\\\"DeviceSigningVerifierNode.JWT: \\\" + signJWT);\\n  outcome = \\\"true\\\";\\n} else {\\n  logger.error(\\\"DeviceSigningVerifierNode.JWT is null!\\\");\\n  outcome = \\\"false\\\";\\n}\\n\""
        }
