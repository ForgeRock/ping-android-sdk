          "context": "AUTHENTICATION_TREE_DECISION_NODE",
          "createdBy": "null",
          "creationDate": 0,
          "default": false,
          "description": "Puts a hard-coded challenge in the shared state object",
          "evaluatorVersion": "1.0",
          "language": "JAVASCRIPT",
          "lastModifiedBy": "null",
          "lastModifiedDate": 0,
          "name": "Hardcoded Challenge",
          "script": "\"/*\\n  - Data made available by nodes that have already executed are available in the sharedState variable.\\n  - The script should set outcome to either \\\"true\\\" or \\\"false\\\".\\n */\\n\\nsharedState.put(\\\"challenge\\\", \\\"my-hardcoded-challenge\\\");\\noutcome = \\\"continue\\\";\""
