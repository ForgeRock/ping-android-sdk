        "49d509cd-5f95-437f-9f71-6a1a5538e350": {
          "_id": "49d509cd-5f95-437f-9f71-6a1a5538e350",
          "context": "AUTHENTICATION_TREE_DECISION_NODE",
          "createdBy": "null",
          "creationDate": 0,
          "default": false,
          "description": "null",
          "evaluatorVersion": "1.0",
          "language": "JAVASCRIPT",
          "lastModifiedBy": "id=0985abcd-9357-4a3f-94f6-9f346b3f19c7,ou=user,ou=am-config",
          "lastModifiedDate": 1753114501252,
          "name": "TextOutputCallbackProducer",
          "script": "\"var fr = JavaImporter(\\n    org.forgerock.openam.auth.node.api.Action, \\n    com.sun.identity.authentication.callbacks.ScriptTextOutputCallback,\\n    javax.security.auth.callback.TextOutputCallback\\n)\\n\\nwith (fr) {\\n  if (callbacks.isEmpty()) {\\n    // Send 4 TextOutput callbacks of all possible types:\\n  \\taction = Action.send(new TextOutputCallback(TextOutputCallback.INFORMATION, \\\"TextOutput Type 0 (INFO)\\\"),\\n                         new TextOutputCallback(TextOutputCallback.WARNING, \\\"TextOutput Type 1 (WARNING)\\\"),\\n                         new TextOutputCallback(TextOutputCallback.ERROR, \\\"TextOutput Type 2 (ERROR)\\\"),\\n                         new ScriptTextOutputCallback(\\\"TextOutput Type 4 (SCRIPT)\\\")).build();\\n  } else {\\n      logger.error(\\\"callbacks.size(): \\\" + callbacks.size());\\n      if (callbacks.size() == 3) {\\n          // Loop through the callbacks to ensure that none of them is of type 4\\n          for (var i = 0; i < callbacks.size(); i++) {\\n            if (callbacks.get(i).getMessageType == 4) {\\n                // The SDK should NOT return TextCallback of type 4\\n                logger.error(\\\"Received unexpected TextCallback of type 4!\\\");\\n                action = fr.Action.goTo(\\\"false\\\").build();\\n                break;\\n            }\\n          }\\n          action = fr.Action.goTo(\\\"true\\\").build();\\n      }\\n      else {\\n          logger.error(\\\"Received unexpected number of callbcks expected 3, but got \\\" + callbacks.size());\\n          action = fr.Action.goTo(\\\"false\\\").build();\\n      }\\n  }\\n}\\n\""
        }
      },
