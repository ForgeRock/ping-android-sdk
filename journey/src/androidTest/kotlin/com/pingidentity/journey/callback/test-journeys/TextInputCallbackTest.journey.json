          "lastModifiedBy": "null",
          "lastModifiedDate": 0,
          "name": "TextInputCallback Producer",
          "script": "\"\\nvar fr = JavaImporter (\\n  org.forgerock.json.JsonValue,\\n  org.forgerock.openam.auth.node.api.Action,\\n  javax.security.auth.callback.TextInputCallback,\\n  java.lang.String\\n);\\n\\n// This is set by the username collector node...\\nvar username = sharedState.get(\\\"username\\\")\\n\\nwith (fr) {\\n  if (callbacks.isEmpty()) {\\n  \\taction = Action.send(new TextInputCallback(\\\"What is your username?\\\", \\\"ForgerRocker\\\")).build();\\n  } else {\\n    // TextInputCallback returned with value\\n    var textInputValue = fr.String(callbacks.get(0).getText());\\n    \\n    // Compare the textInputValue with the username and if they are the same return true\\n    if (username === textInputValue) {\\n       action = fr.Action.goTo(\\\"true\\\").build();\\n    } else {\\n       action = fr.Action.goTo(\\\"false\\\").build();\\n    }\\n  }\\n}\""
        }
