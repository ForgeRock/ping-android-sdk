          "createdBy": "null",
          "creationDate": 0,
          "default": false,
          "description": "This script is used by the Android e2e test cases. It checks if the Device Binding node has included the DeviceBindingCallback.ATTESTATION variable in transient state.",
          "evaluatorVersion": "1.0",
          "language": "JAVASCRIPT",
          "lastModifiedBy": "id=9efa21ef-61ea-4ca9-b0fa-6fbfde82dd8e,ou=user,ou=am-config",
          "lastModifiedDate": 1764618744708,
          "name": "Key Attestation Logger",
          "script": "\"var attestationData = nodeState.get(\\\"DeviceBindingNode.ATTESTATION\\\")\\n\\nif (attestationData) {\\n  logger.message(\\\"DeviceBindingNode.ATTESTATION: \\\" + attestationData);\\n  outcome = \\\"true\\\";\\n} else {\\n  logger.message(\\\"DeviceBindingNode.ATTESTATION is null!\\\");\\n  outcome = \\\"false\\\";\\n}\\n\\n\\n\""
        }
